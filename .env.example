# Grace CLI Configuration
# Copy this to .env and update values as needed
#
# Note: --target-lang (rust/python) is a CLI flag, not an env var.
#   grace techspec <connector> --target-lang python
# Default is `python` when the flag is omitted.

# AI Provider Configuration
# Supported providers: "groq" (default), "litellm"
AI_PROVIDER=groq

# AI API key — required.
# For groq: get one at https://console.groq.com/keys
# For litellm: provider-dependent (OpenAI, Anthropic, GRID, etc.)
AI_API_KEY=your_api_key_here

# AI base URL.
# For groq: https://api.groq.com/openai/v1 (default)
# For litellm: https://grid.ai.juspay.net or your provider's endpoint
AI_BASE_URL=https://api.groq.com/openai/v1

# Model IDs — REQUIRED (no defaults; pick from your provider's catalog).
# Groq catalog: https://console.groq.com/docs/models
#   text examples: llama-3.3-70b-versatile, llama-3.1-8b-instant,
#                  deepseek-r1-distill-llama-70b, mixtral-8x7b-32768
#   vision examples: llama-3.2-11b-vision-preview, llama-3.2-90b-vision-preview
# LiteLLM examples:
#   text:   openai/qwen3-coder-480b, anthropic/claude-sonnet-4-20250514
#   vision: openai/glm-46-fp8
AI_MODEL_ID=
AI_VISION_MODEL_ID=

AI_MAX_TOKENS=32768
AI_TEMPERATURE=0.7

# Firecrawl API Key (required for web scraping via grace techspec -u)
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# TechSpec Configuration
TECHSPEC_OUTPUT_DIR=./rulesbook/codegen-rust/references
TECHSPEC_TEMPERATURE=0.7
TECHSPEC_MAX_TOKENS=32768

# Claude Agent SDK Configuration (for -e enhancement flag)
# Falls back to AI_API_KEY / AI_BASE_URL if these are unset.
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=grace.log
DEBUG=false
